{
  "name": "plcvs-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "PLCVS - Pre-Launch Checklist Verification System UI",
  "main": "electron-dist/main.cjs",
  "type": "module",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@xyflow/react": "^12.6.0",
    "clsx": "^2.1.0",
    "d3": "^7.9.0",
    "lucide-react": "^0.475.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^2.2.0",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
